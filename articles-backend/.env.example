# Network and public URLs
ARTICLES_HOST=127.0.0.1
ARTICLES_PORT=18232
ARTICLES_DATABASE_URL=sqlite:////var/lib/zongrui-articles/articles.db
ARTICLES_MEDIA_DIR=/var/lib/zongrui-articles/media
ARTICLES_PUBLIC_BASE_URL=https://zongrui.org
ARTICLES_MEDIA_PUBLIC_BASE_URL=https://media.zongrui.org/media

# Optional fallback/defence-in-depth when Cloudflare Access is not available.
# Put the same random value in the Pages secret ORIGIN_SHARED_SECRET. The
# backend accepts either environment variable name; never commit the value.
ARTICLES_ORIGIN_SHARED_SECRET=replace-with-openssl-rand-hex-32

# GitHub OAuth application. The numeric user ID is authoritative; the login is
# checked as an additional guard. Never commit the real secret.
ARTICLES_GITHUB_CLIENT_ID=replace-me
ARTICLES_GITHUB_CLIENT_SECRET=replace-me
ARTICLES_ADMIN_GITHUB_USER_ID=98888228
ARTICLES_ADMIN_GITHUB_LOGIN=ZONGRUICHD

# Turnstile is mandatory in production. Tests may explicitly enable the bypass.
ARTICLES_TURNSTILE_SECRET=replace-me
ARTICLES_TURNSTILE_SITE_KEY=replace-me
ARTICLES_TURNSTILE_ACTION=turnstile-spin-v1
ARTICLES_TURNSTILE_BYPASS=false

# At least 32 random bytes. Used only for daily rotating comment source hashes.
ARTICLES_RATE_LIMIT_SECRET=replace-with-openssl-rand-hex-32
ARTICLES_COOKIE_SECURE=true
ARTICLES_TRUST_PROXY_HEADERS=true
