# Private R2 S3 endpoint and restricted bucket credentials. The R2 token must
# have object read/write access only to zongrui-articles-backup.
RESTIC_REPOSITORY=s3:https://ACCOUNT_ID.r2.cloudflarestorage.com/zongrui-articles-backup
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
RESTIC_PASSWORD=replace-with-a-long-random-secret
